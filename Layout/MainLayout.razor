@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="bg-noise"></div>

<NavMenu />

<main>
    @Body
</main>

<footer>
    <div class="footer-top container">
        <div class="footer-brand">
            <img src="images/zylo-logo-dark.png" alt="Zylo Consulting" />
            <p>Enterprise-grade IT solutions for modern businesses. Based in London, serving clients across the UK.</p>
        </div>
        <div class="footer-col">
            <h5>Services</h5>
            <a href="/services">Managed IT</a>
            <a href="/services">Cloud Migration</a>
            <a href="/services">Cybersecurity</a>
            <a href="/services">Technical Support</a>
        </div>
        <div class="footer-col">
            <h5>Company</h5>
            <a href="/about">About Us</a>
            <a href="/blogs">Blog</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="footer-col">
            <h5>Contact</h5>
            <a href="mailto:shaik@zyloconsulting.com">shaik@zyloconsulting.com</a>
            <a href="#">London, United Kingdom</a>
            <a href="https://zyloconsulting.com">zyloconsulting.com</a>
        </div>
    </div>
    <div class="footer-bottom container">
        <p>© 2026 Zylo Consulting Limited. All rights reserved.</p>
        <p>Modern IT for Modern Business</p>
    </div>
</footer>

<div class="mobile-menu" id="mobileMenu">
    <a href="/" @onclick="CloseMobile">Home</a>
    <a href="/services" @onclick="CloseMobile">Services</a>
    <a href="/about" @onclick="CloseMobile">About Us</a>
    <a href="/contact" @onclick="CloseMobile">Contact</a>
    <a href="/blogs" @onclick="CloseMobile">Blog</a>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("siteInit"); }
            catch { /* JS not ready yet - non-fatal */ }
        }
    }
    private async Task CloseMobile()
    {
        try { await JS.InvokeVoidAsync("closeMobileMenu"); }
        catch { /* non-fatal */ }
    }
}
