@inject NavigationManager Nav
@inject IJSRuntime JS

<!-- Utility Top Bar -->
<div class="topbar">
    <div class="container topbar-inner">
        <a href="/" class="topbar-logo">
            <img src="images/zylo-logo-dark.png" alt="Zylo Consulting" />
        </a>

        <a href="/contact" class="btn btn-orange">Get In Touch</a>
    </div>
</div>

<!-- Main Sticky Navbar -->
<nav class="navbar" id="navbar">
    <div class="container navbar-inner">
        <ul class="nav-links">
            <li><a href="/" class="@IsActive("/")">Home</a></li>
            <li><a href="/services" class="@IsActive("/services")">Services</a></li>
            <li><a href="/about" class="@IsActive("/about")">About Us</a></li>
            <li><a href="/blogs" class="@IsActive("/blogs")">Insights</a></li>
            <li><a href="/contact" class="@IsActive("/contact")">Contact</a></li>
        </ul>
        <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle menu" @onclick="ToggleMobile">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
    <a href="/" @onclick="CloseMobile">Home</a>
    <a href="/services" @onclick="CloseMobile">Services</a>
    <a href="/about" @onclick="CloseMobile">About Us</a>
    <a href="/blogs" @onclick="CloseMobile">Insights</a>
    <a href="/contact" @onclick="CloseMobile">Contact</a>
</div>

@code {
    private string IsActive(string href)
    {
        var current = Nav.Uri;
        if (href == "/")
            return current.EndsWith("/") || current == Nav.BaseUri ? "active" : "";
        return current.Contains(href) ? "active" : "";
    }
    private async Task ToggleMobile()
    {
        try { await JS.InvokeVoidAsync("toggleMobileMenu"); } catch { }
    }
    private async Task CloseMobile()
    {
        try { await JS.InvokeVoidAsync("closeMobileMenu"); } catch { }
    }
}
