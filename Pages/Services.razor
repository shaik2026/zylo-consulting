@page "/services"
@inject IJSRuntime JS

<PageTitle>Our Services | Zylo Consulting</PageTitle>

<!-- Page Hero -->
<div class="page-hero">
    <div class="container page-hero-inner">
        <div>
            <h1>Our Services</h1>
            <div class="orange-bar"></div>
        </div>
        <nav class="breadcrumb">
            <a href="/">Home</a>
            <span class="sep">›</span>
            <span class="current">Services</span>
        </nav>
    </div>
</div>

<!-- Intro -->
<section class="section section-gray">
    <div class="container">
        <div class="text-center reveal">
            <span class="section-tag">Enterprise Solutions</span>
            <h2 class="section-title">Comprehensive IT <span class="accent">Services</span></h2>
            <div class="section-underline center"></div>
            <p class="section-subtitle" style="margin: 0 auto;">From day-to-day IT management to full digital transformation, we provide the technology backbone that keeps your business moving forward.</p>
        </div>

        <div class="services-detail-grid">
            <div class="service-detail-card reveal reveal-delay-1">
                <div class="service-detail-top">
                    <div class="icon-wrap">⚙️</div>
                    <h3>Managed IT Services</h3>
                </div>
                <div class="service-detail-body">
                    <p>Fully outsourced IT management for your organisation. Our experts handle everything from helpdesk to infrastructure, letting you focus on your core business.</p>
                    <ul>
                        <li>24/7 helpdesk & remote support</li>
                        <li>Proactive system monitoring</li>
                        <li>Patch management & updates</li>
                        <li>Vendor management</li>
                    </ul>
                </div>
            </div>

            <div class="service-detail-card reveal reveal-delay-2">
                <div class="service-detail-top">
                    <div class="icon-wrap">☁️</div>
                    <h3>Cloud Migration</h3>
                </div>
                <div class="service-detail-body">
                    <p>Seamless migration to cloud platforms with zero-downtime deployments. We manage the entire journey from assessment to go-live and beyond.</p>
                    <ul>
                        <li>Azure, AWS, Google Cloud</li>
                        <li>Cloud readiness assessment</li>
                        <li>Data migration & backup</li>
                        <li>Cost optimisation</li>
                    </ul>
                </div>
            </div>

            <div class="service-detail-card reveal reveal-delay-3">
                <div class="service-detail-top">
                    <div class="icon-wrap">🛡️</div>
                    <h3>Cybersecurity</h3>
                </div>
                <div class="service-detail-body">
                    <p>Comprehensive cybersecurity solutions to protect your business assets, data, and reputation against evolving modern threats.</p>
                    <ul>
                        <li>Penetration testing</li>
                        <li>Threat detection & response</li>
                        <li>GDPR & compliance</li>
                        <li>Security awareness training</li>
                    </ul>
                </div>
            </div>

            <div class="service-detail-card reveal reveal-delay-1">
                <div class="service-detail-top">
                    <div class="icon-wrap">🌐</div>
                    <h3>Network Infrastructure</h3>
                </div>
                <div class="service-detail-body">
                    <p>Design, deploy, and manage enterprise-grade network infrastructure that is secure, resilient, and built to scale with your business.</p>
                    <ul>
                        <li>LAN/WAN design & implementation</li>
                        <li>Firewall management</li>
                        <li>VPN & remote access</li>
                        <li>Network monitoring</li>
                    </ul>
                </div>
            </div>

            <div class="service-detail-card reveal reveal-delay-2">
                <div class="service-detail-top">
                    <div class="icon-wrap">💻</div>
                    <h3>Technical Support</h3>
                </div>
                <div class="service-detail-body">
                    <p>Fast, responsive technical support that minimises downtime and keeps your team productive. Available remotely and on-site.</p>
                    <ul>
                        <li>Multi-channel helpdesk</li>
                        <li>On-site engineer visits</li>
                        <li>Hardware & software support</li>
                        <li>User training</li>
                    </ul>
                </div>
            </div>

            <div class="service-detail-card reveal reveal-delay-3">
                <div class="service-detail-top">
                    <div class="icon-wrap">🔄</div>
                    <h3>Digital Transformation</h3>
                </div>
                <div class="service-detail-body">
                    <p>Strategic guidance to modernise your business processes through intelligent use of technology. We align tech investment with your business outcomes.</p>
                    <ul>
                        <li>IT strategy consulting</li>
                        <li>Process automation</li>
                        <li>Microsoft 365 rollout</li>
                        <li>Technology roadmapping</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-banner-section">
    <div class="container">
        <div class="cta-banner-inner reveal">
            <div class="cta-banner-text">
                <h2>Not sure which service is<br /><span class="highlight">right for your business?</span></h2>
                <p>Talk to one of our consultants for a free, no-obligation discussion about your IT needs.</p>
            </div>
            <a href="/contact" class="btn btn-orange">Book Free Consultation →</a>
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("scrollRevealInit"); } catch { }
        }
    }
}
