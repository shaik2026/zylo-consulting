@page "/contact"
@inject IJSRuntime JS

<PageTitle>Contact Us | Zylo Consulting</PageTitle>

<div class="page-header">
    <span class="section-tag">Say Hello</span>
    <h1>Get In <span class="gradient-text">Touch</span></h1>
    <p>Have a question or ready to start your IT transformation? We'd love to hear from you.</p>
</div>

<section class="section">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info reveal">
                <h2>Let's <span class="gradient-text">Talk</span></h2>
                <p>Whether you need immediate support, want to explore our services, or just want to understand your options — book a free, no-obligation consultation with our team.</p>
                <div class="contact-detail">
                    <div class="contact-icon">📧</div>
                    <div>
                        <h4>Email</h4>
                        <p>shaik@zyloconsulting.com</p>
                    </div>
                </div>
                <div class="contact-detail">
                    <div class="contact-icon">📍</div>
                    <div>
                        <h4>Location</h4>
                        <p>London, United Kingdom</p>
                    </div>
                </div>
                <div class="contact-detail">
                    <div class="contact-icon">🌐</div>
                    <div>
                        <h4>Website</h4>
                        <p>zyloconsulting.com</p>
                    </div>
                </div>
                <div class="contact-detail">
                    <div class="contact-icon">🕐</div>
                    <div>
                        <h4>Support Hours</h4>
                        <p>24/7 for managed clients<br />Mon–Fri 9am–6pm for general enquiries</p>
                    </div>
                </div>
            </div>
            <div class="glass-card reveal reveal-delay-2" style="padding:2.5rem;">
                <h3 style="margin-bottom:1.8rem; font-size:1.4rem;">Send Us a Message</h3>
                <div class="contact-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label>First Name</label>
                            <input type="text" placeholder="John" @bind="FirstName" />
                        </div>
                        <div class="form-group">
                            <label>Last Name</label>
                            <input type="text" placeholder="Smith" @bind="LastName" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" placeholder="john@company.com" @bind="Email" />
                    </div>
                    <div class="form-group">
                        <label>Company (Optional)</label>
                        <input type="text" placeholder="Your Company Ltd" @bind="Company" />
                    </div>
                    <div class="form-group">
                        <label>Service Interested In</label>
                        <select @bind="Service">
                            <option value="">Select a service...</option>
                            <option>Managed IT Services</option>
                            <option>Cloud Migration</option>
                            <option>Cybersecurity</option>
                            <option>Technical Support</option>
                            <option>Network & Infrastructure</option>
                            <option>IT Consultancy</option>
                            <option>General Enquiry</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Message</label>
                        <textarea placeholder="Tell us about your business and IT needs..." @bind="Message"></textarea>
                    </div>
                    @if (Submitted)
                    {
                        <div style="padding:1rem; background:rgba(0,229,255,0.08); border:1px solid rgba(0,229,255,0.2); border-radius:10px; color:var(--cyan); text-align:center; font-weight:500;">
                            ✅ Thank you! We'll be in touch within 1 business day.
                        </div>
                    }
                    else
                    {
                        <button class="btn-primary" style="width:100%; justify-content:center;" @onclick="Submit">
                            Send Message →
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private string FirstName = "";
    private string LastName = "";
    private string Email = "";
    private string Company = "";
    private string Service = "";
    private string Message = "";
    private bool Submitted = false;

    private void Submit()
    {
        if (!string.IsNullOrWhiteSpace(Email) && !string.IsNullOrWhiteSpace(Message))
            Submitted = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("scrollRevealInit");
    }
}
