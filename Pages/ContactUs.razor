@page "/contact"
@inject IJSRuntime JS

<PageTitle>Contact Us | Zylo Consulting</PageTitle>

<!-- Page Hero -->
<div class="page-hero">
    <div class="container page-hero-inner">
        <div>
            <h1>Contact Us</h1>
            <div class="orange-bar"></div>
        </div>
        <nav class="breadcrumb">
            <a href="/">Home</a>
            <span class="sep">›</span>
            <span class="current">Contact</span>
        </nav>
    </div>
</div>

<!-- Contact Section -->
<section class="section section-light">
    <div class="container">
        <div class="contact-grid">
            <!-- Info -->
            <div class="reveal">
                <span class="section-tag">Get In Touch</span>
                <h2 class="section-title">Talk to an <span class="accent">IT Expert</span></h2>
                <div class="section-underline"></div>
                <p style="color:var(--text-light); margin-bottom:36px; line-height:1.8;">Whether you need urgent IT support or want to discuss a longer-term technology strategy, we're here to help. No scripts, no call centres — just real experts ready to listen.</p>

                <div class="contact-info-item">
                    <div class="contact-info-icon">📍</div>
                    <div class="contact-info-text">
                        <strong>Office Address</strong>
                        <span>London, United Kingdom</span>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">📞</div>
                    <div class="contact-info-text">
                        <strong>Phone</strong>
                        <span>+44 (0)20 XXXX XXXX</span>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">✉️</div>
                    <div class="contact-info-text">
                        <strong>Email</strong>
                        <span>info@zyloconsulting.com</span>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">⏰</div>
                    <div class="contact-info-text">
                        <strong>Working Hours</strong>
                        <span>Mon–Fri: 8am–6pm | 24/7 for managed clients</span>
                    </div>
                </div>
            </div>

            <!-- Form -->
            <div class="reveal reveal-delay-2">
                @if (submitted)
                {
                    <div class="form-success">
                        ✅ Thank you! We'll be in touch within one business day.
                    </div>
                }
                <form @onsubmit="HandleSubmit">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                        <div class="form-group">
                            <label>First Name *</label>
                            <input type="text" @bind="model.FirstName" placeholder="John" required />
                        </div>
                        <div class="form-group">
                            <label>Last Name *</label>
                            <input type="text" @bind="model.LastName" placeholder="Smith" required />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Email Address *</label>
                        <input type="email" @bind="model.Email" placeholder="john@company.com" required />
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" @bind="model.Phone" placeholder="+44 xxxx xxxxxx" />
                    </div>
                    <div class="form-group">
                        <label>Service Required</label>
                        <select @bind="model.Service">
                            <option value="">— Select a service —</option>
                            <option>Managed IT Services</option>
                            <option>Cloud Migration</option>
                            <option>Cybersecurity</option>
                            <option>Network Infrastructure</option>
                            <option>Technical Support</option>
                            <option>Digital Transformation</option>
                            <option>Other / General Enquiry</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Your Message *</label>
                        <textarea @bind="model.Message" placeholder="Tell us about your IT challenges or requirements..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-orange" style="width:100%;">Send Message →</button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Stats band -->
<div class="stats-band">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-icon">⚡</div>
                <span class="stat-num">&lt;1hr</span>
                <span class="stat-label">Average Response Time</span>
            </div>
            <div class="stat-item">
                <div class="stat-icon">📞</div>
                <span class="stat-num">24/7</span>
                <span class="stat-label">Emergency Support</span>
            </div>
            <div class="stat-item">
                <div class="stat-icon">👥</div>
                <span class="stat-num">100%</span>
                <span class="stat-label">Client Satisfaction</span>
            </div>
            <div class="stat-item">
                <div class="stat-icon">🇬🇧</div>
                <span class="stat-num">UK</span>
                <span class="stat-label">Based Engineers</span>
            </div>
        </div>
    </div>
</div>

@code {
    private bool submitted = false;
    private ContactModel model = new();

    private class ContactModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Service { get; set; } = "";
        public string Message { get; set; } = "";
    }

    private void HandleSubmit()
    {
        submitted = true;
        model = new();
    }
}
