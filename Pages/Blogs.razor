@page "/blogs"
@inject IJSRuntime JS

<PageTitle>Insights & Blog | Zylo Consulting</PageTitle>

<!-- Page Hero -->
<div class="page-hero">
    <div class="container page-hero-inner">
        <div>
            <h1>Insights &amp; Blog</h1>
            <div class="accent-bar"></div>
        </div>
        <nav class="breadcrumb">
            <a href="/">Home</a>
            <span class="sep">Гўв‚¬Вє</span>
            <span class="current">Insights</span>
        </nav>
    </div>
</div>

<!-- Blog Section -->
<section class="section section-gray">
    <div class="container">
        <div class="reveal">
            <span class="section-tag">Latest Articles</span>
            <h2 class="section-title">IT <span class="accent">Insights</span> & Guides</h2>
            <div class="section-underline"></div>
        </div>

        <!-- Filters -->
        <div class="blog-filters reveal" style="margin-top:24px;">
            @foreach (var tag in tags)
            {
                <button class="filter-btn @(ActiveFilter == tag ? "active" : "")"
                        @onclick="() => ActiveFilter = tag">@tag</button>
            }
        </div>

        <div class="blog-grid">
            @foreach (var (post, i) in FilteredPosts.Select((p, i) => (p, i)))
            {
                <div class="blog-card reveal reveal-delay-@((i % 3) + 1)">
                    <div class="blog-card-top">@post.Emoji</div>
                    <div class="blog-card-body">
                        <span class="blog-tag">@post.Tag</span>
                        <h3>@post.Title</h3>
                        <p>@post.Excerpt</p>
                        <div class="blog-meta">
                            <span>Г°ЕёвЂњвЂ¦ @post.Date</span>
                            <span>ГўВЏВ± @post.ReadTime</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Newsletter CTA -->
<section class="cta-banner-section">
    <div class="container">
        <div class="cta-banner-inner" style="flex-direction:column; text-align:center; gap:24px;">
            <div class="cta-banner-text">
                <h2>Stay up to date with the latest <span class="highlight">IT insights</span></h2>
                <p>Expert tips, guides, and news for technology leaders and business owners.</p>
            </div>
            <a href="/contact" class="btn btn-accent">Subscribe to Updates ГўвЂ вЂ™</a>
        </div>
    </div>
</section>

@code {
    private string ActiveFilter = "All";
    private List<string> tags = new() { "All", "Cloud", "Security", "Managed IT", "Strategy", "Microsoft 365" };

    private record BlogPost(string Emoji, string Tag, string Title, string Excerpt, string Date, string ReadTime);

    private List<BlogPost> AllPosts = new() {
        new("ГўЛњВЃГЇВёВЏ", "Cloud", "Migrating to Azure in 2025: What SMBs Need to Know", "A practical guide to planning and executing a successful Azure migration without disrupting your operations.", "Mar 2025", "5 min read"),
        new("Г°ЕёвЂєВЎГЇВёВЏ", "Security", "Cyber Essentials Plus: Why It Matters for Your Business", "Learn how achieving Cyber Essentials Plus certification can protect your business and win more clients.", "Feb 2025", "6 min read"),
        new("ГўЕЎв„ўГЇВёВЏ", "Managed IT", "5 Signs Your Business Has Outgrown Its IT Support", "Is your IT provider keeping up with your growth? Here are five warning signs to watch for.", "Feb 2025", "4 min read"),
        new("Г°ЕёвЂњЕ ", "Strategy", "Building a 3-Year IT Roadmap: A Guide for SMB Leaders", "How to plan your technology investments strategically to support growth and reduce risk.", "Jan 2025", "7 min read"),
        new("Г°ЕёвЂњВ§", "Microsoft 365", "Getting the Most from Microsoft 365 Copilot", "Practical examples of how businesses are using Microsoft's AI tools to save time and improve productivity.", "Jan 2025", "5 min read"),
        new("Г°ЕёвЂќВђ", "Security", "Phishing Attacks Are Evolving Гўв‚¬вЂќ Is Your Team Ready?", "The latest phishing tactics targeting UK businesses and how to train your staff to recognise them.", "Dec 2024", "4 min read"),
        new("ГўЛњВЃГЇВёВЏ", "Cloud", "Hybrid Cloud vs Full Cloud: What's Right for Your Business?", "Comparing the two approaches to help you make the right infrastructure decision for your organisation.", "Dec 2024", "6 min read"),
        new("ГўЕЎв„ўГЇВёВЏ", "Managed IT", "Why 24/7 IT Monitoring is No Longer Optional", "Downtime costs more than most business owners realise. Here's why proactive monitoring pays for itself.", "Nov 2024", "4 min read"),
        new("Г°ЕёвЂњЕ ", "Strategy", "IT Due Diligence: A Checklist for Business Acquisitions", "When acquiring a business, your IT audit is just as important as your financial due diligence.", "Nov 2024", "8 min read"),
    };

    private IEnumerable<BlogPost> FilteredPosts =>
        ActiveFilter == "All" ? AllPosts : AllPosts.Where(p => p.Tag == ActiveFilter);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("scrollRevealInit"); } catch { }
        }
    }
}
