@page "/about"
@inject IJSRuntime JS

<PageTitle>About Us | Zylo Consulting</PageTitle>

<div class="page-header">
    <span class="section-tag">Our Story</span>
    <h1>About <span class="gradient-text">Zylo Consulting</span></h1>
    <p>A London-based IT consultancy built to give small businesses access to enterprise-grade technology.</p>
</div>

<section class="section">
    <div class="container">
        <div class="about-grid">
            <div class="about-text reveal">
                <span class="section-tag">Who We Are</span>
                <h2>Technology Partner, <span class="gradient-text">Not Just IT Support</span></h2>
                <p>Zylo Consulting Limited was founded with a single mission: to make enterprise-grade IT accessible to businesses of every size. Too many small businesses are left behind by legacy IT providers who over-complicate, over-charge, and under-deliver.</p>
                <p>We believe technology should work for you — reliably, securely, and efficiently. Our team of certified consultants work as an extension of your business, understanding your goals and delivering solutions that actually move the needle.</p>
                <div class="values-grid">
                    <div class="value-card">
                        <div class="icon">🎯</div>
                        <h4>Results-Driven</h4>
                        <p>Every solution is measured by real business outcomes.</p>
                    </div>
                    <div class="value-card">
                        <div class="icon">🔒</div>
                        <h4>Security-First</h4>
                        <p>Security is built-in, not bolted on.</p>
                    </div>
                    <div class="value-card">
                        <div class="icon">💡</div>
                        <h4>Forward-Thinking</h4>
                        <p>We invest in emerging tech so you stay ahead.</p>
                    </div>
                    <div class="value-card">
                        <div class="icon">🤝</div>
                        <h4>Transparent</h4>
                        <p>Clear pricing, honest advice — always.</p>
                    </div>
                </div>
            </div>
            <div class="about-visual reveal reveal-delay-2">
                <div class="about-blob">
                    <div class="blob-inner">
                        <div class="num">5+</div>
                        <p>Years delivering<br />IT excellence</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section" style="padding-top:0;">
    <div class="container">
        <div style="max-width:700px; margin: 0 auto;">
            <div class="section-header reveal" style="text-align:left; margin-bottom:3rem;">
                <span class="section-tag">Our Journey</span>
                <h2 class="section-title">Company <span class="gradient-text">Timeline</span></h2>
            </div>
            <div class="timeline reveal">
                <div class="timeline-item">
                    <div class="year">2019</div>
                    <h4>Founded in London</h4>
                    <p>Zylo Consulting was established to serve small London businesses with professional IT support.</p>
                </div>
                <div class="timeline-item">
                    <div class="year">2021</div>
                    <h4>Cloud Practice Launch</h4>
                    <p>Launched our dedicated cloud migration practice, becoming certified Azure and AWS partners.</p>
                </div>
                <div class="timeline-item">
                    <div class="year">2023</div>
                    <h4>Cybersecurity Division</h4>
                    <p>Expanded into managed cybersecurity services following growing demand from UK businesses post-COVID.</p>
                </div>
                <div class="timeline-item" style="padding-bottom:0;">
                    <div class="year">2026</div>
                    <h4>50+ Clients Served</h4>
                    <p>Reached 50 active clients across London and the wider UK, maintaining a 99.9% uptime SLA record.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section" style="padding-top:0;">
    <div class="container">
        <div class="cta-banner reveal">
            <h2>Want to Know More?</h2>
            <p>Reach out to our team — we're always happy to have a conversation about how we can help your business.</p>
            <a href="/contact" class="btn-primary">Get In Touch →</a>
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("scrollRevealInit");
    }
}
